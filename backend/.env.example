# MongoDB 連線字串（必需）
# 格式: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGO_URI=

# 舊的管理員密碼（向後兼容，可選）
# 建議使用強密碼，例如：openssl rand -hex 32
ADMIN_SECRET=

# JWT 密鑰（必需）- 用於多用戶認證
# 生成方式：openssl rand -hex 32
JWT_SECRET=

# ==================== 前端網址配置 ====================
# 主要前端網址（用於密碼重設連結）
# 系統會按以下順序決定重設連結的網址：
# 1. 優先使用請求的 Origin header（自動偵測）
# 2. 若 Origin 無效，使用此 FRONTEND_URL 環境變數
# 3. 最後才使用 FRONTEND_URLS 的第一個網址
# 範例: https://accounting-system.zeabur.app
FRONTEND_URL=

# ==================== 郵件服務配置（Gmail SMTP）====================
# 用於忘記密碼功能，寄送密碼重設信
# 設定步驟：
# 1. 註冊或使用現有的 Gmail 帳號
# 2. 啟用「兩步驟驗證」: https://myaccount.google.com/security
# 3. 生成「應用程式密碼」: https://myaccount.google.com/apppasswords
#    - 選擇「郵件」和「其他（自訂名稱）」
#    - 記下生成的 16 位密碼（不含空格）
# 4. 填入以下環境變數

SMTP_HOST=smtp.gmail.com                        # SMTP 伺服器（預設: smtp.gmail.com）
SMTP_PORT=587                                   # SMTP 埠號（587=TLS, 465=SSL）
SMTP_USERNAME=your-email@gmail.com              # Gmail 帳號（必需）
SMTP_PASSWORD=                                  # Gmail 應用程式密碼（必需，16位密碼）
SMTP_FROM_EMAIL=your-email@gmail.com            # 寄件者 Email（選填，預設使用 SMTP_USERNAME）

# ==================== 密碼規則配置 ====================
# 所有規則預設為啟用 (true)，可設為 false 來禁用
# 使用 python manage_password_rules.py show 查看當前配置

# 基本要求
PASSWORD_MIN_LENGTH=12                      # 最小密碼長度（預設：12）
PASSWORD_REQUIRE_UPPERCASE=true             # 需要大寫字母
PASSWORD_REQUIRE_LOWERCASE=true             # 需要小寫字母
PASSWORD_REQUIRE_DIGIT=true                 # 需要數字
PASSWORD_REQUIRE_SPECIAL=true               # 需要特殊符號

# 模式檢查
PASSWORD_CHECK_REPEATING=true               # 檢查重複字符（如 aaa）
PASSWORD_CHECK_SEQUENTIAL=true              # 檢查連續字符（如 abcd, 1234）
PASSWORD_CHECK_KEYBOARD_PATTERN=true        # 檢查鍵盤模式（如 qwer, asdf）
PASSWORD_CHECK_COMMON_PASSWORDS=true        # 檢查常見密碼
PASSWORD_CHECK_PERSONAL_INFO=true           # 檢查個人資訊（Email、使用者名稱）
PASSWORD_CHECK_MATH_PATTERNS=true           # 檢查數學模式（費式數列、平方數）
PASSWORD_CHECK_CHINESE_PINYIN=true          # 檢查常見中文拼音

# 限制參數
PASSWORD_MAX_REPEATING=2                    # 最大允許重複次數（預設：2，即3個以上重複會被拒絕）
PASSWORD_MAX_SEQUENTIAL=3                   # 最大允許連續次數（預設：3，即4個以上連續會被拒絕）
PASSWORD_MIN_ENTROPY=50                     # 最小熵值（複雜度，預設：50 bits）

# 密碼規則管理命令：
# python manage_password_rules.py show              # 顯示當前配置
# python manage_password_rules.py enable <rule>     # 啟用規則
# python manage_password_rules.py disable <rule>    # 禁用規則
# python manage_password_rules.py force-update      # 強制所有用戶更新密碼
# python manage_password_rules.py reset-force       # 取消強制更新

# ==================== 部署說明 ====================
# - 本地開發：複製此檔案為 .env 並填入實際值
# - Zeabur：在環境變數設定中直接設定上述變數
# - Heroku：使用 heroku config:set MONGO_URI=your_value
# - Docker：在 docker-compose.yml 中設定環境變數
