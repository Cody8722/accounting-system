[run]
source = .
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */venv/*
    */virtualenv/*
    */.pytest_cache/*
    */migrations/*
    manage_password_rules.py
    migrate_data.py

[report]
# Coverage report settings
precision = 2
show_missing = True
skip_covered = False

# Fail if coverage is below 74%
# Note: 74%+ actual coverage is good for this project
# Main missing coverage is error handling branches and edge cases
fail_under = 74

exclude_lines =
    # Have to re-enable the standard pragma
    pragma: no cover

    # Don't complain about missing debug-only code:
    def __repr__
    if self\.debug

    # Don't complain if tests don't hit defensive assertion code:
    raise AssertionError
    raise NotImplementedError

    # Don't complain if non-runnable code isn't run:
    if 0:
    if __name__ == .__main__.:
    if TYPE_CHECKING:

    # Don't complain about abstract methods
    @(abc\.)?abstractmethod

[html]
directory = htmlcov

[xml]
output = coverage.xml
